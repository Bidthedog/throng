{
  "name": "throng",
  "version": "0.0.0",
  "private": true,
  "description": "throng — project-first terminal & agent workspace",
  "author": "Christopher Sebok",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bidthedog/throng.git"
  },
  "bugs": {
    "url": "https://github.com/Bidthedog/throng/issues"
  },
  "homepage": "https://github.com/Bidthedog/throng#readme",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build:renderer --workspace @throng/ui && npm run stamp:build",
    "stamp:build": "node scripts/stamp-build.mjs",
    "build:renderer": "npm run build:renderer --workspace @throng/ui",
    "clean": "tsc -b --clean",
    "start": "npm run build && npm run start:ui",
    "start:admin": "npm run build && node scripts/start-admin.mjs",
    "test:e2e:admin": "npm run build && node scripts/test-e2e-admin.mjs",
    "start:daemon": "node packages/daemon/dist/main.js",
    "start:ui": "electron packages/ui/dist/main/main.js",
    "test": "node scripts/run-tests.mjs",
    "pretest:e2e": "npm run build",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:contract": "vitest run --project contract",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^26.1.0",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "playwright": "^1.48.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "inversify": "^8.1.1",
    "reflect-metadata": "^0.2.2"
  }
}
